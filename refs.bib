@article{selfVibrationAnalysis,
author = {Ma, Hongzhong and Liu, Baowen and Xu, Honghua and Chen, Bingbing and Ju, Ping and Zhang, Li and Qu, Bin},
title = {GIS mechanical state identification and defect diagnosis technology based on self-excited vibration of assembled circuit breaker},
journal = {IET Science, Measurement \& Technology},
volume = {14},
number = {1},
pages = {56-63},
keywords = {circuit breakers, fault diagnosis, condition monitoring, gas insulated switchgear, support vector machines, particle swarm optimisation, vibrations, power engineering computing, defect diagnosis technology, self-excited vibration, assembled circuit breaker, condition monitoring, gas-insulated switchgear, operating energy, noninvasive techniques, vibration signals, vibration signatures, typical mechanical failures, static mechanisms, drive mechanisms, signal processing, decision-making techniques, GIS mechanical condition, GIS mechanical fault-diagnosis technology, voltage 126.0 kV, S},
doi = {https://doi.org/10.1049/iet-smt.2018.5578},
url = {https://ietresearch.onlinelibrary.wiley.com/doi/abs/10.1049/iet-smt.2018.5578},
eprint = {https://ietresearch.onlinelibrary.wiley.com/doi/pdf/10.1049/iet-smt.2018.5578},
abstract = {Condition monitoring has been widely used to detect electrical faults of gas-insulated switchgear (GIS), but little attention has been paid to diagnosing the mechanical failures. Owing to the fact that the operating energy of circuit breaker assembled in GIS is large enough to stimulate the whole GIS to vibrate, in this study, non-invasive techniques for evaluating the mechanical condition of GIS by considering the vibration signals excited by the operation of circuit breaker are implemented. Vibration signatures of five typical mechanical failures sated on both static mechanisms and drive mechanisms were extracted from a 126kV GIS test system. In addition, new algorithms for signal processing and decision-making techniques based on the combination of energy equipartition S-transform and particle swarm optimisation support vector machine classifier were proposed. A practical diagnostic instrument was developed and applicated on line for identifying the GIS mechanical condition. Experimental and field demonstration verified the effectiveness of the proposed GIS mechanical fault-diagnosis technology.},
year = {2020}
}

